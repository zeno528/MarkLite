# i18n 翻译脚本配置 — 用于 scripts/translate.mjs
# 用法：复制本文件为 .env，填入下面 3 个变量

# ===== LLM API =====
# API 地址（OpenAI 兼容格式，DeepSeek / OpenAI / 通义千问 / Moonshot 等都支持）
# 默认 DeepSeek；想换其他服务就改这行
LLM_API_URL=https://api.deepseek.com/v1/chat/completions

# 模型名（按你用的服务填）
# DeepSeek: deepseek-v4-pro（高质量）/ deepseek-v4-flash（推荐，便宜 12 倍）
# OpenAI:   gpt-4o-mini / gpt-4o
# 通义:     qwen-turbo / qwen-plus
LLM_MODEL=deepseek-v4-pro

# API Key（必填，去对应平台申请）
# DeepSeek: https://platform.deepseek.com/
# OpenAI:   https://platform.openai.com/
LLM_API_KEY=sk-your-key-here