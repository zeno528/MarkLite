{
  "$schema": "https://schema.tauri.app/config/2",
 "productName": "MarkLite",
  "version": "0.3.1",
 "identifier": "studio.scott.marklite",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MarkLite",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": true,
        "windowEffects": { "effects": [] },
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**/*", "$DOCUMENT/**/*", "$DESKTOP/**/*"],
          "deny": []
        }
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "resources": ["icons/md-file.ico"],
    "shortDescription": "轻量级 Markdown 编辑器",
    "longDescription": "MarkLite 是一款轻量、秒开、跨平台（macOS + Windows）的现代化 Markdown 编辑器，基于 Tauri + React + CodeMirror 6 构建。",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "installerHooks": "./nsis-hooks.nsh"
      }
    }
  }
}
